# Discord bot credentials (required)
DISCORD_BOT_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-client-id-here
DISCORD_GUILD_ID=your-development-server-id   # optional: for dev/testing

# Interaction mode (optional, default: gateway)
INTERACTIONS_MODE=gateway                      # "gateway" or "http"
# DISCORD_PUBLIC_KEY=your-public-key-hex       # required only for http mode
# PORT=3000                                    # optional, default 3000

# Storage backend (optional, default: memory)
STORAGE_BACKEND=memory                         # "memory" or "redis"
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...

# Session TTL in hours (optional, default: 6)
# SESSION_TTL_HOURS=6

# Legal URL overrides (optional — fallback to GitHub repo URLs)
# TERMS_OF_SERVICE_URL=https://your-domain.com/terms
# PRIVACY_POLICY_URL=https://your-domain.com/privacy
# SUPPORT_SERVER_LINK=https://discord.gg/your-invite-code
# DEVELOPER_CONTACT_EMAIL=privacy@your-domain.com