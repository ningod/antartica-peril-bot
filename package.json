{
  "name": "antartica-peril-bot",
  "version": "0.1.0",
  "description": "Discord bot for Antartica TTRPG — Brave the Peril procedure (Tag extraction engine)",
  "license": "MIT",
  "author": "Stefano Vetrini",
  "repository": {
    "type": "git",
    "url": "https://github.com/ningod/antartica-peril-bot"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm src/index.ts",
    "deploy-commands": "node --loader ts-node/esm src/deploy-commands.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@upstash/redis": "^1.34.3",
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.5",
    "discord-api-types": "^0.37.120",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.2",
    "prettier": "^3.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.0.7"
  }
}
